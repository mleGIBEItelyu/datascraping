# Optional. If set, the FRED API (api.stlouisfed.org) is used as a macro data
# source before falling back to DBnomics. Get a free key at:
# https://fred.stlouisfed.org/docs/api/api_key.html
#
# Copy this file to .env (which is gitignored) and put your real key there.
# Do NOT commit a real key to this template file.
FRED_API_KEY=
